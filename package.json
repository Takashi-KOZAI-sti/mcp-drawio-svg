{
  "name": "mcp-drawio-svg",
  "version": "0.1.0",
  "description": "MCP server that generates .drawio.svg files — editable in draw.io and embeddable as SVG in Markdown",
  "author": "Takashi Kozai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tkozai/mcp-drawio-svg.git"
  },
  "keywords": ["mcp", "drawio", "svg", "diagram", "draw.io", "claude", "ai"],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
